import java.util.Scanner;
class Main {
    public static void main(String[] args) {
        Scanner z=new Scanner(System.in);
    System.out.println("Enter the total number of candies");
    int n=z.nextInt();
    System.out.println("Enter the minimum candies");
    int s=z.nextInt();
     System.out.println("Enter the candies the Customer wants");
     int a=z.nextInt();
    if(a>n||n-a<s){
        System.out.println("Invalid input");
    }
    else{
        n=n-a;
        System.out.println("Number of candies sold:"+a);
        System.out.println("Number of candies available:"+n);
    }
    }
    
    }
